<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Descargando Phasmophobia...</title>

<style>
body {
  margin: 0;
  background: black;
  overflow: hidden;
  font-family: Arial;
}

#pantalla {
  position: absolute;
  width: 100%;
  top: 40%;
  text-align: center;
  color: white;
}

img {
  position: absolute;
  width: 250px;
}
</style>
</head>

<body>

<div id="pantalla">
  <h1>Descargando Phasmophobia...</h1>
  <p id="progreso">0%</p>
</div>

<script>

// PROGRESO
let progreso = 0;
let inicioTroll = false;

// TUS IMÁGENES
const imagenes = [
  "https://cdn.discordapp.com/attachments/1310762053987733596/1490187777009127474/Captura_de_pantalla_2026-02-24_142529.png?ex=69e4f144&is=69e39fc4&hm=50aec69293005e3d998c7a874fe1c7c6b1a7b946ce3040ac41de90833ad43479&",
  "https://cdn.discordapp.com/attachments/1310762053987733596/1490187777009127474/Captura_de_pantalla_2026-02-24_142529.png?ex=69e4f144&is=69e39fc4&hm=50aec69293005e3d998c7a874fe1c7c6b1a7b946ce3040ac41de90833ad43479&",
  "https://cdn.discordapp.com/attachments/1310762053987733596/1490187777009127474/Captura_de_pantalla_2026-02-24_142529.png?ex=69e4f144&is=69e39fc4&hm=50aec69293005e3d998c7a874fe1c7c6b1a7b946ce3040ac41de90833ad43479&"
];

let indice = 0;

let intervalo = setInterval(() => {

  if (progreso < 50) {
    progreso += 2;
    document.getElementById("progreso").innerText = progreso + "%";
  }

  if (progreso >= 50 && !inicioTroll) {
    inicioTroll = true;
    iniciarTroll();
  }

}, 100);


// TROLL
function iniciarTroll() {

  // empiezan a aparecer imágenes
  let lluvia = setInterval(() => {

    const img = document.createElement("img");

    img.src = imagenes[indice % imagenes.length];

    img.style.top = Math.random() * (window.innerHeight - 250) + "px";
    img.style.left = Math.random() * (window.innerWidth - 250) + "px";

    document.body.appendChild(img);

    indice++;

  }, 80);

  // texto
  let texto = document.createElement("div");
  texto.innerText = "WACHIN";
  texto.style.position = "fixed";
  texto.style.top = "40%";
  texto.style.width = "100%";
  texto.style.textAlign = "center";
  texto.style.fontSize = "70px";
  texto.style.color = "red";

  document.body.appendChild(texto);

  // ⏳ después de unos segundos → redirige
  setTimeout(() => {
    window.location.href = "https://www.youtube.com/watch?v=tTrfrT2HAnM";
  }, 4000); // 4 segundos (podés cambiarlo)
}

</script>

</body>
</html>
